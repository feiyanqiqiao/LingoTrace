# Default to private: ignore everything unless explicitly allowlisted below.
*

# Public repository metadata.
!.gitignore
!AGENTS.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!LICENSE
!SECURITY.md

# Public GitHub automation.
!.github/
!.github/dependabot.yml
!.github/workflows/
!.github/workflows/*.yml
!.github/workflows/*.yaml

# Public documentation.
!docs/
!docs/*.md

# Public docs.
!docs/
!docs/**

# Public runtime source and tests.
!lingotrace/
!lingotrace/**
!tests/
!tests/lingotrace/
!tests/lingotrace/**

# Public listening tooling.
!tools/
!tools/README.md
!tools/listening-transcribe-official/
!tools/listening-transcribe-official/**
!tools/architecture-baseline/
!tools/architecture-baseline/**
!tools/vault-structure/
!tools/vault-structure/**
!tools/git/
!tools/git/**
tools/vault-structure/**/__pycache__/
tools/vault-structure/**/*.pyc

# Always keep local/editor/cache/media/private material out of Git.
.DS_Store
**/.DS_Store
.obsidian/
tmp/
学习系统/
笔记/

__pycache__/
**/__pycache__/
.pytest_cache/
.venv/
*.pyc
*.pyo
*.mp3
*.m4a
*.wav
*.flac
*.mp4
*.mov
*.webm
*.pdf
*.jpg
*.jpeg
*.png
*.heic
